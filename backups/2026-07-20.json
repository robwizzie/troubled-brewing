    "testimonials": [
      {
        "id": "a85e67ed-0a65-46ab-977f-48a5b7b651e1",
        "author": "Hazel Stjernelys",
        "source": "Google",
        "rating": 5,
        "quote": "While browsing for coffee shops in the area, this one caught my eye. It did not disappoint! This shop is cozy, clearly loved by locals, and has plenty of seating without feeling overcrowded. Chosen decor includes foxes and mushrooms and adds the right touch of whimsy 🍄\nI'm not out this way often but I'll definitely stop again the next time I am!",
        "featured": false,
        "display_order": 0,
        "status": "published",
        "draft_data": null,
        "created_at": "2026-07-13T21:04:20.842448+00:00",
        "image_url": ""
      },
      {
        "id": "e8d84e17-a1a9-4130-ae6e-d0acaeb39ca5",
        "author": "Cory Mathews",
        "source": "Google",
        "rating": 5,
        "quote": "Good coffee for a good price. Blueberry scone was very good massive Blueberrys barista Tyler was friendly and fast would visit again when on a trip from California",
        "featured": false,
        "display_order": 0,
        "status": "published",
        "draft_data": null,
        "created_at": "2026-07-13T21:04:23.404874+00:00",
        "image_url": ""
      },
      {
        "id": "45f23059-8ca2-4a63-b4d9-53930c79eb07",
        "author": "Leticia Vega",
        "source": "Google",
        "rating": 5,
        "quote": "My son and I stopped in to have a hot chia and cold latte with breakfast sandwiches and pastries. Great service, drinks and food great. Beautiful town. Been there before. Bonus--it's dog friendly 🦮. Definitely will be back.",
        "featured": false,
        "display_order": 0,
        "status": "published",
        "draft_data": null,
        "created_at": "2026-07-13T21:04:23.948377+00:00",
        "image_url": ""
      },
      {
        "id": "2239f639-cb08-46aa-9c9e-3d4dde8b7e68",
        "author": "Heather Roth",
        "source": "Google",
        "rating": 5,
        "quote": "Definitely one of my favorite coffee shops that I have come across. I love that they collaborate with other local businesses. I’m a big fan of their Milky Way iced coffee, and their breakfast sandwiches are delicious. I love hanging out inside or outside. Their staff are fantastic. I love chatting with them every time I go in.",
        "featured": false,
        "display_order": 0,
        "status": "published",
        "draft_data": null,
        "created_at": "2026-07-13T21:04:24.298524+00:00",
        "image_url": ""
      }
