# Copy this file to `.env` for local development. NEVER commit `.env`.
# In production these are injected by the GitHub Actions deploy workflow
# from repository secrets (see docs/DEPLOYMENT.md).
#
# The anon key is SAFE to ship in the client bundle — it is gated by Supabase
# Row Level Security. NEVER put the service_role key here or anywhere client-side.

# --- Supabase (public reads + admin auth) ---
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# --- Google Analytics 4 (optional; analytics only loads after consent) ---
VITE_GA4_MEASUREMENT_ID=

# --- Online ordering: the shop's hosted SpotOn Order URL ---
# Used by the "Order Now" button everywhere. Get the exact URL from the client.
VITE_SPOTON_ORDER_URL=https://www.spoton.com/order/

# --- Public site URL (used for canonical + sitemap + JSON-LD) ---
VITE_SITE_URL=https://troublebrewingcoffeehouse.com
